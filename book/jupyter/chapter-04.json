9,"column":1},"end":{"line":89,"column":1}},"key":"LFN8VemPIA"}],"key":"uFX9dzVwbd"},{"type":"paragraph","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"children":[{"type":"text","value":"Some NI-DAQmx devices have discrete allowable sample rates, while others can have any sample rate that is desired up to some maximum value.  Please refer to the documentation of your device to determine which sample rates are allowable for your device.  The NI-DAQmx drivers, when provided an incompatible sample rate, often simply select the closest available rate or the next highest rate, which can result in data being acquired at a rate that is not equivalent to the rate selected in the software.  Additionally, further issues can occur when the sample rate of an output device is not compatible with the sample rate of an acquisition device, meaning the output is being delivered at a different rate than it is being measured, resulting in inconsistent data.  ","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"o92K4bq2RV"},{"type":"strong","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"children":[{"type":"text","value":"Currently Rattlesnake does not do very rigorous checks to determine if the specified sample rate is allowable, so it falls on the user to ensure that it is!","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"OfwEBfb1Ts"}],"key":"jqBaxCW8ro"}],"key":"Wk4xElodWg"}],"label":"warn:ni_sample_rate","identifier":"warn:ni_sample_rate","html_id":"warn-ni-sample-rate","key":"NzRloxoBUK"},{"type":"heading","depth":3,"position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"Implementation Details ","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"x9OCAd3tZ7"},{"type":"comment","value":"Section 4.3","key":"zII2HAH80z"}],"identifier":"implementation-details-section-4-3","label":"Implementation Details Section 4.3","html_id":"implementation-details-section-4-3","implicit":true,"enumerator":"4.3","key":"SuMpt2NbwR"},{"type":"paragraph","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"text","value":"This section contains details on the NI-DAQmx implementation in Rattlesnake, which may be helpful for users when diagnosing issues that arise in the controller.","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"key":"pbvZDJWfMR"}],"key":"razFYph5Ux"},{"type":"heading","depth":4,"position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"children":[{"type":"text","value":"NI-DAQmx Tasks ","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"fdEnAKY9Nz"},{"type":"comment","value":"Subsection 4.3.1","key":"PvQDnhVSBV"}],"identifier":"ni-daqmx-tasks-subsection-4-3-1","label":"NI-DAQmx Tasks Subsection 4.3.1","html_id":"ni-daqmx-tasks-subsection-4-3-1","implicit":true,"enumerator":"4.3.1","key":"kMAG6wgHjA"},{"type":"paragraph","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"children":[{"type":"text","value":"NI-DAQmx hardware interfaces are defined within Tasks.  The acquisition exists within one task.  The output exists within one or more more separate tasks with one task per type of output card.  This multi-task output enables, for example, two different types of output cards to be used in the same chassis.","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"y6xt05sTXE"}],"key":"VveTd0YCDA"},{"type":"heading","depth":4,"position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"children":[{"type":"text","value":"Sampling Parameters ","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"key":"xHcDjksPss"},{"type":"comment","value":"Subsection 4.3.2","key":"nv1RfiAOYX"}],"identifier":"sampling-parameters-subsection-4-3-2","label":"Sampling Parameters Subsection 4.3.2","html_id":"sampling-parameters-subsection-4-3-2","implicit":true,"enumerator":"4.3.2","key":"c5pRJYr123"},{"type":"paragraph","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"children":[{"type":"text","value":"Both acquisition and output operate in continuous mode.  This means that if the controller cannot output signals fast enough and the hardware runs out of samples to generate, the controller will throw an error and stop abruptly.  A buffer size of three times the number of samples per write is specified in the source code which gives a cushion against the controller falling behind.  The output will accept a set of samples into the output buffer whenever there is less than two writes worth of samples remaining in the buffer.  The buffer size is computed by subtracting the total samples generated by the output task from the current write position in the output tasks buffer.","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"OasuP7IpbM"}],"key":"jxCyWwUSFS"},{"type":"heading","depth":4,"position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"Starting the Hardware ","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"key":"wdWhf56wQr"},{"type":"comment","value":"Subsection 4.3.3","key":"rjDiXbLi0F"}],"identifier":"starting-the-hardware-subsection-4-3-3","label":"Starting the Hardware Subsection 4.3.3","html_id":"starting-the-hardware-subsection-4-3-3","implicit":true,"enumerator":"4.3.3","key":"z970YRIF0h"},{"type":"paragraph","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"children":[{"type":"text","value":"When a measurement is started, the output is set up and started first.  The output task uses a start trigger from an analog input task (","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"a3uZjkUVW3"},{"type":"inlineCode","value":"/<physical_device_name>/ai/StartTrigger","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"t6hVNEHJMv"},{"type":"text","value":") as its trigger, so once it starts, it effectively waits for the acquisition to be set up and started.  To determine which start trigger is used, it checks if the device is a cDAQ device.  If the device is a cDAQ device, it uses the start trigger from the cDAQ chassis.  If it is not a cDAQ device, it utilizes the start trigger from the first analog input channel.  This configuration has been tested with both cDAQ and PXI devices.  When the acquisition is started, its start trigger will trigger the output to start outputting signals simultaneously.  Because the system tries to use the analog input start trigger for all outputs, users may have trouble daisy-chaining multiple chassis together if the trigger signal is not able to be passed between all of the chassis.","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"SjFTfSXSkE"}],"key":"GWjTeOjkfC"}],"key":"PvkU7Tznji"}],"key":"wryZ5aGcIm"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Part 2: Rattlesnake Hardware Devices","url":"/part-2","group":"Rattlesnake Vibration Controller"},"next":{"title":"LAN-XI Devices","url":"/chapter-05","group":"Rattlesnake Vibration Controller"}}},"domain":"http://localhost:3000"}