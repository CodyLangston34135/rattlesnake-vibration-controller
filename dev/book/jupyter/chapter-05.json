{"version":3,"kind":"Article","sha256":"9648e96e88f53fc27c8efdc8692ac8a292528b02bff2028060a8c6eef34da028","slug":"chapter-05","location":"/book/src/chapter_05.md","dependencies":[],"frontmatter":{"title":"LAN-XI Devices","numbering":{"heading_1":{"enabled":true,"continue":false},"heading_2":{"start":5,"enabled":true,"template":"Chapter %s"},"figure":{"enumerator":"5.%s","enabled":true,"continue":false},"table":{"enumerator":"5.%s","enabled":true,"continue":false},"equation":{"enumerator":"5.%s","enabled":true,"continue":false},"heading_3":{"enabled":true},"heading_4":{"enabled":true},"heading_5":{"enabled":true},"heading_6":{"enabled":true},"code":{"enumerator":"5.%s","enabled":true},"title":{"offset":1}},"content_includes_title":false,"github":"https://github.com/sandialabs/rattlesnake-vibration-controller","keywords":["mimo","vibration","modal","structural-dynamics"],"abbreviations":{"6DoF":"Six Degree-of-Freedom","API":"Application Programming Interface","APSD":"Auto-Power Spectral Density","CCLD":"Constant Current Line Drive","COLA":"Constant Overlap and Add","CPSD":"Cross-Power Spectral Density","FEM":"Finite Element Model","FFT":"Fast Fourier Transform","FRF":"Frequency Response Function","GUI":"Graphical User Interface","ICP":"Integrated Circuit Piezoelectric","IDE":"Integrated Development Environment","IEPE":"Integrated Electronics PiezoElectric","IFFT":"Inverse Fast Fourier Transform","IP":"Internet Protocol","JSON":"Javascript Object Notation","MIMO":"Multiple Input, Multiple Output","ReST":"Representational State Transfer","RMS":"Root-Mean-Square","SVD":"Singular Value Decomposition","TRAC":"Time Response Assurance Criterion","UI":"User Interface"},"source_url":"https://github.com/sandialabs/rattlesnake-vibration-controller/blob/main/documentation/book/src/chapter_05.md","edit_url":"https://github.com/sandialabs/rattlesnake-vibration-controller/edit/main/documentation/book/src/chapter_05.md","thumbnail":"/rattlesnake-vibration-controller/dev/book/jupyter/