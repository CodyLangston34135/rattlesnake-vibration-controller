sition":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"zmqeIWpNVd"},{"type":"text","value":", ","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"rg0pNeZexT"},{"type":"inlineCode","value":"7.0 Hz","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"zlQ1v2wNVs"},{"type":"text","value":", ","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"T6n5ZW9y97"},{"type":"inlineCode","value":"22.4 Hz","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"mobs4MhUjc"},{"type":"text","value":", or ","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"vuHcRHsOhs"},{"type":"inlineCode","value":"Intensity","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"abh6gVfn62"},{"type":"text","value":".","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"VW4u0w1gHq"}],"key":"dS5pKMy16D"},{"type":"paragraph","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"Current Excitation Source is used to specify if a channel uses ","key":"bihLsw6Hdi"},{"type":"abbreviation","title":"Constant Current Line Drive","children":[{"type":"text","value":"CCLD","key":"PBLKCN20OM"}],"key":"mVnPrJgony"},{"type":"text","value":" or not.  If ","key":"yJ0f4EfYh8"},{"type":"abbreviation","title":"Constant Current Line Drive","children":[{"type":"text","value":"CCLD","key":"mpsGJiXyw7"}],"key":"MrQPPCLMUc"},{"type":"text","value":" is to be used on a given channel the Current Excitation Source column should contain ","key":"KMk8oEJREl"},{"type":"inlineCode","value":"CCLD","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"lKyHl5Dwxe"},{"type":"text","value":".  If ","key":"jBDZ5YfLye"},{"type":"abbreviation","title":"Constant Current Line Drive","children":[{"type":"text","value":"CCLD","key":"rq0yJwAwrE"}],"key":"ijhCXdFe8v"},{"type":"text","value":" is not to be used for that channel, the column can be left blank.","key":"gIt3AO1alL"}],"key":"svsv6eMsPF"},{"type":"heading","depth":3,"position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Hardware Parametters ","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"GNInpgbqiV"},{"type":"comment","value":"Section 5.2","key":"yQfuGn0IbJ"}],"identifier":"hardware-parametters-section-5-2","label":"Hardware Parametters Section 5.2","html_id":"hardware-parametters-section-5-2","implicit":true,"enumerator":"5.2","key":"wTrTZhfQAN"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"LAN-XI hardware devices have discrete sample rates, which are powers of 2 staring with 4096 samples per second.  The minimum sample rate of the generator is 16,384 Hz, so the output must be over-sampled if the acquisition sample rate is less than 16,384 samples per second.  Environments defined in Rattlesnake must be able to handle output oversampling when required by the hardware device.","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"MFyWp5Bj0Z"}],"key":"ix3aapXoU2"},{"type":"paragraph","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"children":[{"type":"text","value":"For large channel count tests, Rattlesnake struggles to pull data off the acquisition device fast enough using just one process.  Therefore, a maximum number of acquisition processes can be specified.  If too few processes are used, it will take longer to read data off the hardware than it took to acquire the data.  This will result in the controller falling behind and the data buffer on the hardware slowly filling.  Alternatively if too many processes are used, the computer running Rattlesnake will get bogged down swapping between processes, and other parts of the controller (particularly the ","key":"Jck9I2FmTW"},{"type":"abbreviation","title":"Graphical User Interface","children":[{"type":"text","value":"GUI","key":"sdUAc72vjR"}],"key":"zABZyRuadC"},{"type":"text","value":") may become slow.  Generally, 20-40 channels per process is a reasonable rule of thumb, though this will depend on the Sample Rate of the hardware.","key":"vdFi0CIZki"}],"key":"wdbgMbxGuL"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/rattlesnake-vibration-controller/dev/book/jupyter//build/lanxi_data_acquisiti-6bf9999bba7687ac1733f6299acaf4c7.png","alt":"LAN-XI data acquisition parameters.","align":"center","data":{"altTextIsAutoGenerated":true},"key":"ST5QPE24rF","urlSource":"figures/lanxi_data_acquisition_parameters.png"},{"type":"caption","children":[{"type":"paragraph","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"captionNumber","kind":"figure","label":"fig:lanxi_data_acquisition_parameters","identifier":"fig:lanxi_data_acquisition_parameters","html_id":"fig-lanxi-data-acquisition-parameters","enumerator":"5.2","children":[{"type":"text","value":"Figure ","key":"yE1pRTGoV5"},{"type":"text","value":"5.2","key":"vQnTPZKMXP"},{"type":"text","value":":","key":"RnvQSlHayI"}],"template":"Figure %s:","key":"U1Q8t0XvZd"},{"type":"text","value":"LAN-XI data acquisition parameters.","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"sXx194pf96"}],"key":"IkeBMYZuWw"}],"key":"wu16rJ9E2O"}],"label":"fig:lanxi_data_acquisition_parameters","identifier":"fig:lanxi_data_acquisition_parameters","enumerator":"5.2","html_id":"fig-lanxi-data-acquisition-parameters","key":"lEekrXbkpa"},{"type":"heading","depth":3,"position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"text","value":"Implementation Details ","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"LN7ecfTnaq"},{"type":"comment","value":"Section 5.3","key":"noIM3ddboN"}],"identifier":"implementation-details-section-5-3","label":"Implementation Details Section 5.3","html_id":"implementation-details-section-5-3","implicit":true,"enumerator":"5.3","key":"ZTHKOtPJMg"},{"type":"paragraph","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"text","value":"This section contains details on the LAN-XI implementation in Rattlesnake, which may be helpful for users when diagnosing issues that arise in the controller.","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"inVdH3i0S8"}],"key":"B6WIgU9BXr"},{"type":"heading","depth":4,"position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"abbreviation","title":"Representational State Transfer","children":[{"type":"text","value":"ReST","key":"KTr9fK94sr"}],"key":"cY03MGbdpr"},{"type":"text","value":" ","key":"uE2n32xogP"},{"type":"abbreviation","title":"Application Programming Interface","children":[{"type":"text","value":"API","key":"tfaQMG9P46"}],"key":"n026U4alCj"},{"type":"text","value":" ","key":"TmtU2ACDs6"},{"type":"comment","value":"Subsection 5.3.1","key":"hGoEsSPbsj"}],"identifier":"rest-api-subsection-5-3-1","label":"ReST API Subsection 5.3.1","html_id":"rest-api-subsection-5-3-1","implicit":true,"enumerator":"5.3.1","key":"uE2hfVoUnl"},{"type":"paragraph","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"children":[{"type":"text","value":"Rattlesnake communicates with the LAN-XI using a ","key":"BmfBQJqwBu"},{"type":"abbreviation","title":"Representational State Transfer","children":[{"type":"text","value":"ReST","key":"ILW4uj3XBg"}],"key":"bqDqiw0i4o"},{"type":"text","value":" interface.  Rattlesnake sends and receives ","key":"t6gTaR3KWS"},{"type":"abbreviation","title":"Javascript Object Notation","children":[{"type":"text","value":"JSON","key":"lSw6MFEPRN"}],"key":"IK6p4Ij22y"},{"type":"text","value":" packages that define state transitions in the hardware using HTTP commands.","key":"KZYueEZVqw"}],"key":"FSkgvjSIZj"},{"type":"heading","depth":4,"position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"children":[{"type":"text","value":"Setting up the LAN-XI ","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"ZMiQtTg24A"},{"type":"comment","value":"Subsection 5.3.2","key":"etLNn4PkSV"}],"identifier":"setting-up-the-lan-xi-subsection-5-3-2","label":"Setting up the LAN-XI Subsection 5.3.2","html_id":"setting-up-the-lan-xi-subsection-5-3-2","implicit":true,"enumerator":"5.3.2","key":"NnAKDOGeNX"},{"type":"paragraph","position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"children":[{"type":"text","value":"The LAN-XI hardware is set up primarily by the Output process of the controller.  The LAN-XI hardware can be used in either single or multi-module mode.  It will generally take a while to set up the LAN-XI configuration.  Lights will flash on the LAN-XI hardware while the setup is occurring, and information will be printed to the command terminal that appears when Rattlesnake is run.  When the LAN-XI setup is completed, the statement ","position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"key":"TnuY21achx"},{"type":"inlineCode","value":"Data Acquisition Ready for Acquire","position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"key":"KrbpFnNjjX"},{"type":"text","value":" will be printed to the command terminal.  Do not start a test prior to seeing this message.","position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"key":"Rn0cXFMSG0"}],"key":"CrJyjsKE2H"},{"type":"paragraph","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"children":[{"type":"text","value":"Various network issues and firewall settings can block or slow down data transfer between the LAN-XI hardware and the computer running Rattlesnake.  These issues are out of the scope of this document to diagnose and correct; users are encouraged to contact their network administrator if such issues arise.","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"key":"vECCuIbmV5"}],"key":"NswBinqncX"},{"type":"paragraph","position":{"start":{"line":73,"column":1},"end":{"line":73,"column":1}},"children":[{"type":"text","value":"It has been found that for larger channel count tests (typically three or more 11-card frames used simultaneously) that individual cards can hang during this setup process.  The authors currently do not know why this occurs, as the exact same setup configuration causes no issues with lower channel counts.  Cycling power on the hardware devices has been found to resolve this issue.","position":{"start":{"line":73,"column":1},"end":{"line":73,"column":1}},"key":"W8PufOo4g3"}],"key":"CltYsawYSC"},{"type":"heading","depth":4,"position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"children":[{"type":"text","value":"Acquistion Processes ","position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"key":"fC4P34rosr"},{"type":"comment","value":"Subsection 5.3.3","key":"VkRsyBDt0G"}],"identifier":"acquistion-processes-subsection-5-3-3","label":"Acquistion Processes Subsection 5.3.3","html_id":"acquistion-processes-subsection-5-3-3","implicit":true,"enumerator":"5.3.3","key":"KjqVA1tGfq"},{"type":"paragraph","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"children":[{"type":"text","value":"The LAN-XI interface used by Rattlesnake uses multiple processes to acquire data from the hardware.  When starting to acquire data, Rattlesnake starts a number of processes less than or equal to the maximum number of acquisition processes allowed on the ","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"khfFND3UdL"},{"type":"inlineCode","value":"Data Acquisition Setup","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"TIvS37Fr83"},{"type":"text","value":" tab.  Each process will generally handle multiple hardware modules, with each module having one socket over which the data communication occurs.  After all sockets are connected, the measurement is started.","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"U67ZSrIQpp"}],"key":"dy59BTE1CZ"},{"type":"paragraph","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"children":[{"type":"text","value":"Raw data is read from each module by the various acquisition processes and put into queues that are read by the main acquisition process.  The main acquisition process takes these data and assembles them into the data array that is required by the controller.","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"key":"kOtCoibcje"}],"key":"Xy7PtNCnnh"},{"type":"paragraph","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"When an acquisition activity ends, the Rattlesnake process will attempt to recover the LAN-XI subprocesses.  When all processes have been recovered, the LAN-XI interface will print ","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"XfaWmXaPvD"},{"type":"inlineCode","value":"All processes recovered, ready for next acquire.","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"FvoqEi7DuR"},{"type":"text","value":" to the command terminal.  Periodically, one of these processes may not be recovered successfully, which will cause the acquisition process to hang.  It is currently unknown why this occurs.","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"WBkYyF2uRz"}],"key":"KYQNdFi3iF"},{"type":"heading","depth":4,"position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"text","value":"Decoding Acquisition Data ","position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"key":"jyRrti3dCA"},{"type":"comment","value":"Subsection 5.3.4","key":"BwfyzmukNC"}],"identifier":"decoding-acquisition-data-subsection-5-3-4","label":"Decoding Acquisition Data Subsection 5.3.4","html_id":"decoding-acquisition-data-subsection-5-3-4","implicit":true,"enumerator":"5.3.4","key":"gJ75q4986s"},{"type":"paragraph","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"children":[{"type":"text","value":"Raw acquisition data is provided to the controller from the hardware as bytes that must be interpreted correctly to be meaningful.  A data stream from the hardware consists of messages transmitted sequentially.  The message header is always 28 bytes long and specifies what type of message is being transmitted as well as the total length of the message.  This then allows the socket reader to receive the rest of the message.  Message types read by the Rattlesnake can either be “interpretations” or “signals”. Interpretation messages specify how the subsequent signal data is to be interpreted and are sent whenever a signal changes.  Interpretations provide an offset and a scale factor to apply to the raw acquisition data to create the physical measurements.  Signal messages carry the raw acquisition data.  Rattlesnake uses Kaitai Struct to decode the binary data stream into Python objects which are accessed by the controller.","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"JXlxCcx8K9"}],"key":"NBl1h7vrZs"},{"type":"heading","depth":4,"position":{"start":{"line":87,"column":1},"end":{"line":87,"column":1}},"children":[{"type":"text","value":"Encoding Output Data ","position":{"start":{"line":87,"column":1},"end":{"line":87,"column":1}},"key":"OWDHw6iWfc"},{"type":"comment","value":"Subsection 5.3.5","key":"mDfKzJvrPJ"}],"identifier":"encoding-output-data-subsection-5-3-5","label":"Encoding Output Data Subsection 5.3.5","html_id":"encoding-output-data-subsection-5-3-5","implicit":true,"enumerator":"5.3.5","key":"yKRknX9M2A"},{"type":"paragraph","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"Data is provided to the hardware for output in bytes as well.  LAN-XI hardware accepts output data as the 32-bit integers with only the upper 24 bits used.  Floating point signals that are desired to be output are divided by 10 and multiplied by 8,372,224.  These values are then truncated to integers and converted to bytes.  These bytes are then sent via socket communications to the generator on the LAN-XI module.","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"LMNyJxBKM0"}],"key":"CUCr7hofpc"},{"type":"heading","depth":4,"position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Output Oversampling ","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"IAMMsoY9VN"},{"type":"comment","value":"Subsection 5.3.6","key":"EcEodKXQTB"}],"identifier":"output-oversampling-subsection-5-3-6","label":"Output Oversampling Subsection 5.3.6","html_id":"output-oversampling-subsection-5-3-6","implicit":true,"enumerator":"5.3.6","key":"m74LDEReks"},{"type":"paragraph","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"The generator on the LAN-XI module always runs at its full rate of 131,072 samples per second.  If the acquisition sample rate is equal to or greater than 16,384 samples per second, the LAN-XI hardware performs over-sampling automatically.  However, if the sample rate is less than 16,384, Rattlesnake must over-sample its output.  It is left to each environment within Rattlesnake to determine how to handle the oversampling of its output data.  For ","key":"HfRRlYnvrR"},{"type":"abbreviation","title":"Fast Fourier Transform","children":[{"type":"text","value":"FFT","key":"ztzF27lk8e"}],"key":"y9VabJOb3g"},{"type":"text","value":"-based environments, this can be as simple as padding the ","key":"VfZEoznIPg"},{"type":"abbreviation","title":"Fast Fourier Transform","children":[{"type":"text","value":"FFT","key":"pzTbwmUWae"}],"key":"seN9829Qsm"},{"type":"text","value":" with zeros prior to creating the signal.  For time-based environments, more thought must be given to ensure signals are not made to be discontinuous by the up-sampling procedure.","key":"r2RUTaHBRY"}],"key":"mJFsqVrkxi"},{"type":"heading","depth":4,"position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"text","value":"Starting Up and Running the LAN-XI Acquisition ","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"key":"Rsb6UPEzbh"},{"type":"comment","value":"Subsection 5.3.7","key":"pQ5KCXhoPx"}],"identifier":"starting-up-and-running-the-lan-xi-acquisition-subsection-5-3-7","label":"Starting Up and Running the LAN-XI Acquisition Subsection 5.3.7","html_id":"starting-up-and-running-the-lan-xi-acquisition-subsection-5-3-7","implicit":true,"enumerator":"5.3.7","key":"H6V95ylZ8l"},{"type":"paragraph","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"children":[{"type":"text","value":"When an acquisition is started, the LAN-XI will immediately start acquiring data.  Rattlesnake may take some time to set up all of the required network connections to the device, so there may be a delay between starting the acquisition and receiving data in the Rattlesnake software.  During this time, the buffer on the hardware will start to fill up.  Once Rattlesnake starts pulling data off the LAN-XI device, the buffer will generally empty, as Rattlesnake ideally can pull data off the device faster than it is acquired.  For each read, Rattlesnake will print the amount of time it took to read to the command terminal.  Initially, the value reported will be smaller than the ","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"TKZMTs5CNg"},{"type":"inlineCode","value":"Time per Read","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"FZDb6MWbVy"},{"type":"text","value":" value that is specified on the ","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"cUmAT7SwBU"},{"type":"inlineCode","value":"Data Acquisition Setup","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"TcdKftMOo0"},{"type":"text","value":" tab, because the software will be pulling data off of the hardware buffer that has accumulated during the delay in starting up the measurement.  After the buffer is emptied, users should see that the value reported will hover around ","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"PweGvDpZsd"},{"type":"inlineCode","value":"Time per Read","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"IJige4RpJP"},{"type":"text","value":" value that is specified on the ","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"S7lkoPzW2r"},{"type":"inlineCode","value":"Data Acquisition Setup","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"OTS0PjTKlY"},{"type":"text","value":" tab, because that is the amount of time it takes to fill the buffer enough for the next read.  The value may be lower or higher for any given read, but on average, it should be approximately equal to the ","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"OWRphf4Rgp"},{"type":"inlineCode","value":"Time per Read","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"Qt3V2NIu66"},{"type":"text","value":" value.  For maximal controller responsiveness, we want the hardware buffer to be empty so we can react to new data as quickly as possible, so it is therefore a good practice to not start any environment until the time that it is taking to read data becomes approximately equal to the specified ","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"jgc3yqGYX3"},{"type":"inlineCode","value":"Time per Read","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"BdBCt04gfX"},{"type":"text","value":" value.","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"BEQ6nrraF0"}],"key":"f6BdkBSJTo"},{"type":"paragraph","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"children":[{"type":"text","value":"If the user notices that it is consistently taking more time to perform a single read than the ","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"taqoIq7Ynh"},{"type":"inlineCode","value":"Time per Read","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"ssCS0m8sCf"},{"type":"text","value":" value that was specified, it typically means that the software cannot pull data off the hardware quickly enough.  This could be due to poor network speeds or a firewall interfering with the transfer.  It could also mean that the user should increase the ","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"MVnfHnYPfD"},{"type":"inlineCode","value":"Maximum Acquisition Processes","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"koMK5RnJLY"},{"type":"text","value":" value specified on the ","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"WltCtM2msW"},{"type":"inlineCode","value":"Data Acquisition Setup","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"EynLkEsfvt"},{"type":"text","value":" page.  If it consistently takes more time per read than the value specified in the ","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"v3k9A15UxM"},{"type":"inlineCode","value":"Time per Read","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"RMLM5CU0WI"},{"type":"text","value":" field, this means that the hardware buffer is filling up.  The controller will be responding to increasingly older data, and will not be responsive.  Finally, if the hardware buffer becomes full, the acquisition may simply stop entirely as there is no room to put more data.","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"QyhXUuILAY"}],"key":"p3OWViSA9o"}],"key":"JuYzf19ZeD"}],"key":"RzahDjY2EY"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"NI-DAQmx Devices","url":"/chapter-04","group":"Rattlesnake Vibration Controller"},"next":{"title":"Data Physics Quattro Devices","url":"/chapter-06","group":"Rattlesnake Vibration Controller"}}},"domain":"http://localhost:3000"}