    <layout class="QHBoxLayout" name="prediction_layout">
     <item>
      <layout class="QGridLayout" name="excitation_prediction_layout">
       <item row="2" column="1">
        <widget class="QComboBox" name="excitation_column_selector">
         <property name="toolTip">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Excitation CPSD Column Channel&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Select the column of the excitation CPSD matrix to visualize&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
