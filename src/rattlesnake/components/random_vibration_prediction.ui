        <widget class="PlotWidget" name="excitation_display_plot">
         <property name="sizePolicy">
          <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
           <horstretch>1</horstretch>
           <verstretch>0</verstretch>
          </sizepolicy>
         </property>
         <property name="toolTip">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Excitation Display Plot&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Shows the specified portion of the CPSD matrix.  If an off-diagonal term is selected, both real and imaginary parts will be plotted.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
         </property>
        </widget>
       </item>
       <item row="0" column="0">
