        <widget class="QPushButton" name="minimum_voltage_button">
         <property name="toolTip">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Go to Minimum Excitation&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Shows the excitation channel with the smallest voltage&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
