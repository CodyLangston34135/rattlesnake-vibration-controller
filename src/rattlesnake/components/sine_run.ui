         <layout class="QHBoxLayout" name="horizontalLayout_4">
          <item>
           <widget class="PlotWidget" name="phase_plot">
            <property name="toolTip">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Response Phase Plot&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Plots the response phase compared to the specification for the selected control channel and sine tone.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
