          <item>
           <widget class="PlotWidget" name="amplitude_plot">
            <property name="toolTip">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Response Amplitude Plot&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Plots the response amplitude compared to the specification for the selected control channel and sine tone.  Additionally plots warning and abort limits if specified.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
