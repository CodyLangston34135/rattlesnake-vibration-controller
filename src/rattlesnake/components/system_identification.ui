       <layout class="QGridLayout" name="gridLayout">
        <item row="0" column="0">
         <widget class="QPushButton" name="preview_noise_button">
          <property name="toolTip">
           <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Preview Noise&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Starts the noise identification of the system identification process in preview mode.  No excitation will be applied to the shakers.  The preview will continue until stopped manually.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
          </property>
          <property name="text">
           <string>Preview Noise</string>
          </property>
