     <item>
      <widget class="QGroupBox" name="reference_channels_groupbox">
       <property name="title">
        <string>Channel Selections</string>
       </property>
       <layout class="QVBoxLayout" name="verticalLayout_3">
        <item>
         <widget class="QTableWidget" name="reference_channels_selector">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Minimum" vsizetype="Expanding">
            <horstretch>0</horstretch>
            <verstretch>0</verstretch>
           </sizepolicy>
          </property>
          <property name="toolTip">
           <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Channel Selection Table&lt;/span&gt;&lt;/p&gt;&lt;p&gt;By checking the box in the Reference column, a channel can be made into a reference channel rather than a response channel.  Unchecking the box in the Enabled column with disable the channel.  Disabling an excitation channel will disable that excitation device.  Disabling a reference will remove that reference from the FRF computation.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
          </property>
          <property name="sizeAdjustPolicy">
           <enum>QAbstractScrollArea::AdjustToContents</enum>
          </property>
          <property name="selectionBehavior">
           <enum>QAbstractItemView::SelectRows</enum>
          </property>
          <attribute name="horizontalHeaderDefaultSectionSize">
           <number>70</number>
          </attribute>
          <attribute name="horizontalHeaderMinimumSectionSize">
           <number>70</number>
          </attribute>
          <column>
           <property name="text">
            <string>Enabled</string>
           </property>
           <property name="toolTip">
            <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Enabled&lt;/span&gt;&lt;/p&gt;&lt;p&gt;If checked, the given channel is enabled for the measurement.  Disabling excitation channels will disable that excitation device.  Disabling references will remove them from the computation.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
           </property>
          </column>
          <column>
           <property name="text">
            <string>Reference</string>
           </property>
           <property name="toolTip">
            <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Reference&lt;/span&gt;&lt;/p&gt;&lt;p&gt;If checked, the given channel is used as a reference for computing frequency response functions.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
           </property>
          </column>
          <column>
           <property name="text">
            <string>Channel</string>
           </property>
           <property name="toolTip">
            <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Channel&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Name of the channel used by the Modal Environment&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
           </property>
          </column>
         </widget>
        </item>
        <item>
         <layout class="QGridLayout" name="button_grid">
          <item row="1" column="0">
           <widget class="QPushButton" name="disable_selected_button">
            <property name="toolTip">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Disable Selected&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Disables the currently selected channels in the Channel Selections table&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
            <property name="text">
             <string>Disable
Selected</string>
            </property>
           </widget>
          </item>
          <item row="0" column="0">
           <widget class="QPushButton" name="enable_selected_button">
            <property name="toolTip">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Enable Selected&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Enables the channels currently selected in the Channel Selections table&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
            <property name="text">
             <string>Enable
Selected</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="QPushButton" name="check_selected_button">
            <property name="toolTip">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Check Selected References&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Turns the selected channels into reference channels for computing FRFs&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
            <property name="text">
             <string>Check Selected
References</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <widget class="QPushButton" name="uncheck_selected_button">
            <property name="toolTip">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Uncheck Selected References&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Turns the selected channels into response channels for computing FRFs&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
            <property name="text">
             <string>Uncheck Selected
References</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
     </item>
     <item>
      <layout class="QVBoxLayout" name="signal_generator_layout">
       <item>
        <widget class="QGroupBox" name="signal_generator_groupbox">
         <property name="title">
          <string>Signal Generator</string>
         </property>
         <layout class="QVBoxLayout" name="verticalLayout_12">
          <item>
           <widget class="QTabWidget" name="signal_generator_selector">
            <property name="sizePolicy">
             <sizepolicy hsizetype="Minimum" vsizetype="Minimum">
              <horstretch>0</horstretch>
              <verstretch>0</verstretch>
             </sizepolicy>
            </property>
            <property name="toolTip">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Signal Generation Tabs&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Switching tabs will change the type of excitation signal that will be output.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
            <property name="currentIndex">
             <number>0</number>
            </property>
            <widget class="QWidget" name="no_excitation_tab">
             <attribute name="title">
              <string>No Signal Generation</string>
             </attribute>
             <layout class="QVBoxLayout" name="verticalLayout_18">
              <item>
               <widget class="QLabel" name="no_excitation_label">
                <property name="text">
                 <string>No signal will be generated</string>
                </property>
               </widget>
              </item>
             </layout>
            </widget>
            <widget class="QWidget" name="random_excitation_tab">
             <attribute name="title">
              <string>Random</string>
             </attribute>
             <layout class="QHBoxLayout" name="horizontalLayout_5">
              <item>
               <layout class="QVBoxLayout" name="random_rms_layout">
                <item>
                 <widget class="QLabel" name="random_rms_label">
                  <property name="text">
                   <string>RMS</string>
                  </property>
                 </widget>
                </item>
                <item>
                 <layout class="QHBoxLayout" name="random_rms_selector_layout">
                  <item>
                   <widget class="QDoubleSpinBox" name="random_rms_selector">
                    <property name="toolTip">
                     <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Random RMS&lt;/span&gt;&lt;/p&gt;&lt;p&gt;RMS voltage level of the Random signal&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
                    </property>
                    <property name="keyboardTracking">
                     <bool>false</bool>
                    </property>
                    <property name="maximum">
                     <double>10.000000000000000</double>
                    </property>
                    <property name="value">
                     <double>0.010000000000000</double>
                    </property>
                   </widget>
                  </item>
                  <item>
                   <widget class="QLabel" name="random_rms_selector_label">
                    <property name="text">
                     <string>V</string>
                    </property>
                   </widget>
                  </item>
                 </layout>
                </item>
               </layout>
              </item>
              <item>
               <layout class="QVBoxLayout" name="random_frequency_range_layout">
                <item>
                 <widget class="QLabel" name="random_frequency_range_label">
                  <property name="text">
                   <string>Frequency Range</string>
                  </property>
                 </widget>
                </item>
                <item>
